/* css/layout.css */

/*
    Hata Ayıklama Notu:
    Bu dosya, uygulamanın genel iskeletini ve ana panellerin düzenini tanımlar.
    CSS kurallarının doğru uygulandığını doğrulamak için tarayıcının Geliştirici Araçları'nda (Developer Tools)
    "Elements" (Öğeler) sekmesini kullanarak `#app-wrapper`, `#main-header`, `#main-content`,
    `#student-comment-dashboard`, `.panel` gibi ana elemanların Flexbox/Grid özelliklerini
    ve boyutlandırmalarını kontrol edebilirsiniz.
    Özellikle yatay ve dikey hizalamaları, boşlukları (gap) ve esneklik (flex) ayarlarını
    doğru görselleştirildiğinden emin olun.
*/

/* Genel Düzen Ayarları */
body {
    /* global.css'te flex ayarları yapıldı, burada tekrar etmiyoruz */
}

#app-wrapper {
    /* global.css'te temel ayarları yapıldı */
    /* Ekstra düzen ayarları: flex-direction: column olarak ayarlandı */
}

/* --- Başlık (Header) Düzeni --- */
#main-header {
    /* global.css'te temel stil ve position: sticky ayarları yapıldı */
    /* Ek düzen ayarları */
}

.header-content {
    /* global.css'te temel flex ayarları yapıldı */
}

.header-controls {
    /* global.css'te temel flex ayarları yapıldı */
}

/* Dashboard Kartları Kapsayıcısı */
#dashboard-cards-container {
    display: flex;
    justify-content: space-around;
    align-items: center;
    width: 100%;
    padding: var(--spacing-sm) var(--spacing-lg);
    background-color: rgba(0,0,0,0.1); /* Hafif şeffaf arka plan */
    gap: var(--spacing-sm);
    flex-wrap: nowrap; /* Kartların tek satırda kalmasını sağlar */
    box-sizing: border-box;
    min-height: 60px; /* Minimum yükseklik */
    overflow-x: auto; /* Küçük ekranlarda yatay kaydırma */
    -webkit-overflow-scrolling: touch;
    flex-shrink: 0;

    /* Sticky Header altında sabit durması için */
    position: sticky;
    top: var(--header-height, 70px); /* JS tarafından güncellenecek, şimdilik varsayılan */
    z-index: 99;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1); /* Hafif gölge */
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
}

/* Dashboard kartlarının kendileri (components.css'te daha detaylı) */
.dashboard-card {
    flex-grow: 1;
    flex-basis: 0; /* İçeriğe göre genişlemesini sağlar */
    min-width: 90px; /* Kartlar için minimum genişlik */
    padding: var(--spacing-xs) var(--spacing-sm);
}


/* --- Ana İçerik Alanı Düzeni --- */
#main-content {
    flex-grow: 1;
    display: flex; /* İçindeki section'ları düzenlemek için flex kullanıyoruz */
    padding: var(--spacing-lg);
}

/* Öğrenci ve Yorum Ana Paneli */
#student-comment-dashboard {
    display: flex;
    flex-wrap: wrap; /* Küçük ekranlarda alt alta düşmesini sağlar */
    gap: var(--spacing-lg);
    width: 100%;
    min-height: calc(100vh - var(--header-height, 130px) - var(--spacing-xl) * 2); /* Ekran yüksekliğine göre ayarla */
}

.panel {
    background-color: var(--secondary-bg-color);
    border-radius: 8px;
    padding: var(--spacing-lg);
    box-shadow: 0 3px 15px var(--shadow-color); /* Daha belirgin gölge */
    display: flex;
    flex-direction: column;
}

/* Sol Panel (Öğrenci Listesi) */
.student-list-panel {
    flex: 1.2; /* Yorum paneline göre biraz daha dar */
    min-width: 300px; /* Minimum genişlik */
    max-width: 400px; /* Maksimum genişlik */
}

/* Sağ Panel (Yorum Düzenleyici ve Şablonlar) */
.comment-editor-panel {
    flex: 2; /* Daha geniş alan kaplar */
    min-width: 450px; /* Minimum genişlik */
    flex-grow: 1; /* Mevcut alanı doldurmasını sağlar */
}

/* Liste alanları için flex ayarları */
#student-list-container,
#comment-profile-list {
    flex-grow: 1; /* İçeriğin kalan alanı doldurmasını sağlar */
    min-height: 150px; /* Minimum yükseklik */
}

.list-footer-controls {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-lg);
    justify-content: center;
}

.list-footer-controls .button {
    flex-grow: 1;
    flex-basis: calc(50% - var(--spacing-xs)); /* Yarı yarıya bölüşsün */
    max-width: calc(50% - var(--spacing-xs));
}


/* --- Öğrenci Yönetimi Modalı İçindeki Düzen --- */
#student-management-modal .modal-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
}

.modal-tabs {
    display: flex;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: var(--spacing-md);
}

.modal-tab-button {
    flex-grow: 1;
    padding: var(--spacing-sm);
    background-color: transparent;
    border: none;
    border-bottom: 3px solid transparent;
    font-size: var(--font-size-base);
    font-weight: 500;
    color: var(--text-color-light);
    cursor: pointer;
    transition: all 0.2s ease;
}

.modal-tab-button:hover {
    color: var(--text-color-dark);
    background-color: var(--primary-bg-color);
}

.modal-tab-button.active {
    color: var(--current-primary-color);
    border-bottom-color: var(--current-primary-color);
    font-weight: 600;
}

.modal-tab-content {
    display: none;
    flex-grow: 1; /* İçeriğin kalanı doldurmasını sağlar */
    padding-top: var(--spacing-md); /* Tab butonu ile içeriği ayır */
    overflow-y: auto; /* İçerik taşarsa kaydırma çubuğu */
}

.modal-tab-content.active {
    display: flex;
    flex-direction: column;
}

.form-group-inline { /* Modal içindeki form grubu için yeni sınıf */
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
    margin-bottom: var(--spacing-md);
}

.form-group-inline > * {
    flex-grow: 1;
    flex-basis: calc(50% - var(--spacing-xs));
    max-width: calc(50% - var(--spacing-xs));
}

.modal-footer-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-lg);
    justify-content: flex-end;
    border-top: 1px solid var(--border-color);
    padding-top: var(--spacing-md);
}

.modal-footer-actions .button {
    flex-grow: 1;
    flex-basis: calc(50% - var(--spacing-xs));
    max-width: calc(50% - var(--spacing-xs));
}